# Вариант 2: Реализовать «Обратную польскую запись» (RPN): вычисление выражения 3 4 + 2 *.

def evaluate_rpn(expression):
    stack = []
    tokens = expression.split()

    for token in tokens:
        if token.isdigit():  # если число
            stack.append(int(token))
        else:
            b = stack.pop()
            a = stack.pop()

            if token == '+':
                stack.append(a + b)
            elif token == '-':
                stack.append(a - b)
            elif token == '*':
                stack.append(a * b)
            elif token == '/':
                stack.append(a / b)

    return stack[0]

expr = "3 4 + 2 *"
result = evaluate_rpn(expr)
print("Результат:", result)

